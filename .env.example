# Veřejná URL webu (bez koncového lomítka) — důležité pro Stripe redirecty
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin přístup (/admin/rezervace)
ADMIN_EMAIL=admin@neurea.cz
ADMIN_PASSWORD=change-me
ADMIN_MAGIC_TOKEN=change-me-magic-token
ADMIN_COOKIE_SECRET=change-me-cookie-secret

# Uložení rezervací (lokálně / server-side)
# Pro produkci doporučuji přesunout na databázi (Postgres/Supabase).
BOOKINGS_DATA_DIR=/tmp/neurea

# Dočasně: na stránce /rezervace zobrazit platbu „Test 10 Kč“ (Stripe účtuje 10 Kč). Po testu smaž nebo nastav na false.
RESERVATION_TEST_10KC_ENABLED=false
