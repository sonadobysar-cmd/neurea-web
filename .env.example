# Veřejná URL webu (bez koncového lomítka) — důležité pro Stripe redirecty po platbě.
# Na Vercelu vždy https:// a stejná doména jako v prohlížeči (včetně www), např.:
# NEXT_PUBLIC_SITE_URL=https://www.neurea.cz
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Potvrzovací e-mail po platbě (Resend — https://resend.com, ověř doménu pro „from“)
RESEND_API_KEY=re_...
# Např. NEUREA <rezervace@neurea.cz> — musí být z ověřené domény v Resend
EMAIL_FROM="NEUREA <rezervace@neurea.cz>"

# Admin přístup (/admin/rezervace)
ADMIN_EMAIL=admin@neurea.cz
ADMIN_PASSWORD=change-me
ADMIN_MAGIC_TOKEN=change-me-magic-token
ADMIN_COOKIE_SECRET=change-me-cookie-secret

# Uložení rezervací (lokálně / server-side)
# Pro produkci doporučuji přesunout na databázi (Postgres/Supabase).
BOOKINGS_DATA_DIR=/tmp/neurea

# Připomínkový e-mail den před termínem (cron /api/cron/reminders)
# Na Vercelu nastav stejnou hodnotu; cron volá endpoint s hlavičkou Authorization: Bearer <CRON_SECRET>
CRON_SECRET=change-me-long-random-string
